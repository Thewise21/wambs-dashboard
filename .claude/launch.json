{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "WAMB'S Dashboard (React Dev)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 3000
    },
    {
      "name": "WAMB'S Dashboard (Production Build)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-s", "build", "-l", "5000"],
      "port": 5000
    },
    {
      "name": "mockup-preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "mockup-preview", "-p", "8090", "-c-1"],
      "port": 8090
    }
  ]
}
